Algoritmo ejercicio2repetitiva
	Definir numero1 Como Entero
	Definir factorialnumero Como Entero
	Escribir "dame un numero "
	Leer numero1
	factorialnumero=1
	Mientras numero1 >= 1 Hacer
		factorialnumero=factorialnumero*numero1
		Escribir numero1
		numero1=numero1-1
	Fin Mientras
	
	Escribir "Su factorial es: " factorialnumero
	
FinAlgoritmo
